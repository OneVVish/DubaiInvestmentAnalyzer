# Copy this file to .env for local development.
#
# The Google Apps Script Web App "/exec" URL that receives scenario logs and
# serves the passphrase-gated admin view — see google-apps-script/README.md
# for how to create it. Not secret (it only allows anonymous writes; reads
# are gated by ADMIN_SECRET inside the script itself), but left out of
# version control anyway so a real deployed URL isn't committed by accident.
VITE_SCENARIO_LOG_URL=
